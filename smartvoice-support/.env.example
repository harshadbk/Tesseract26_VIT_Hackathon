# Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# API CONFIGURATION
# ============================================

# Backend API URL
REACT_APP_API_URL=http://localhost:5000

# Environment (development, staging, production)
REACT_APP_ENVIRONMENT=development

# ============================================
# OPTIONAL: AI SERVICES (If using frontend-side APIs)
# ============================================

# OpenAI API Key (keep in backend, not frontend)
# REACT_APP_OPENAI_API_KEY=your_key_here

# ============================================
# OPTIONAL: ANALYTICS
# ============================================

# Google Analytics ID
# REACT_APP_GA_ID=UA-XXXXX-X

# ============================================
# OPTIONAL: SUPABASE (Direct client use)
# ============================================

# Supabase URL and Key (if using Supabase)
# REACT_APP_SUPABASE_URL=https://your-project.supabase.co
# REACT_APP_SUPABASE_KEY=your_supabase_key

# ============================================
# OPTIONAL: SENTRY (Error tracking)
# ============================================

# Sentry DSN for error tracking
# REACT_APP_SENTRY_DSN=https://your_sentry_url

# ============================================
# APPLICATION SETTINGS
# ============================================

# App name for display
REACT_APP_NAME=SmartVoice Support

# Version
REACT_APP_VERSION=1.0.0

# ============================================
# FEATURE FLAGS (optional)
# ============================================

# Enable voice input
REACT_APP_VOICE_INPUT_ENABLED=true

# Enable emotion detection
REACT_APP_EMOTION_DETECTION_ENABLED=true

# Enable auto-escalation
REACT_APP_AUTO_ESCALATION_ENABLED=true

# Enable analytics
REACT_APP_ANALYTICS_ENABLED=false

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Debug mode (shows console logs)
REACT_APP_DEBUG_MODE=true

# Log API requests
REACT_APP_LOG_API_REQUESTS=true
