# Vite environment template
# Copy this file to ".env" for local development

# Frontend mode:
# false = demo mode (no backend requests, no Vite proxy errors)
# true  = connect to backend APIs
VITE_ENABLE_BACKEND=true

# Backend base URL (used only when VITE_ENABLE_BACKEND=true)
# If you keep Vite proxy, you can use /api
VITE_API_URL=/api

# Vite dev proxy target for /api (set this if your backend runs on another port)
VITE_BACKEND_TARGET=http://localhost:8000

# If backend is briefly down, frontend waits this many ms before trying backend again
VITE_BACKEND_RETRY_MS=8000

# Optional app meta
VITE_APP_NAME=SmartVoice Support Agent
